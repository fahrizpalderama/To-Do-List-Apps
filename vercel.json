{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server.ts"
    },
    {
      "source": "/auth/callback",
      "destination": "/server.ts"
    },
    {
      "source": "/((?!api/|auth/callback).*)",
      "destination": "/index.html"
    }
  ]
}
